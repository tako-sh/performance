{
    auto_https off
    admin off
}

https://bench.test:18443 {
    tls /opt/tako-performance/certs/bench.test.crt /opt/tako-performance/certs/bench.test.key
    rate_limit {
        zone per_ip {
            key {remote_host}
            events {$CADDY_RATE_LIMIT_EVENTS:65535}
            window {$CADDY_RATE_LIMIT_WINDOW:1s}
        }
    }
    reverse_proxy 127.0.0.1:9101
}
